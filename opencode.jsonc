{
	"$schema": "https://opencode.ai/config.json",
	"mcp": {
		"open-design": {
			"type": "local",
			"command": ["npx", "-y", "@nexu-io/open-design", "mcp"],
			"enabled": true,
		},
		"convex": {
			"type": "local",
			"command": ["npx", "-y", "convex@latest", "mcp", "start"],
			"enabled": true,
		},
		"context7": {
			"type": "remote",
			"url": "https://mcp.context7.com/mcp",
			"enabled": true,
		},
	},
}
